NODE_ENV=development
PORT=5000
APP_NAME=job-portal-api

# Database
DB_URL=mongodb://localhost:27017/job-portal-api
# DB_URI=mongodb://localhost:27017/job-portal-api
# MONGODB_URI=mongodb://localhost:27017/job-portal-api
# If Atlas SRV DNS fails on your network, use non-SRV URI format from Atlas driver page:
# DB_URL=mongodb://<host1>:27017,<host2>:27017,<host3>:27017/<db>?replicaSet=<rs>&ssl=true&authSource=admin&retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_jwt_secret
JWT_ACCESS_SECRET=change_this_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Client
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Session
EXPRESS_SESSION_SECRET=change_this_session_secret

# Payment providers
SSL_COMMERZ_STORE_ID=
SSL_COMMERZ_STORE_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# Optional admin bootstrap
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin User
DEFAULT_ADMIN_PHONE=
