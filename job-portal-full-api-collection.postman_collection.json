          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate@example.com\",\n  \"password\": \"StrongP@ssw0rd\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const d = json.data || json;",
                  "pm.expect(d.accessToken || d.token).to.exist;",
                  "if (d.accessToken) pm.collectionVariables.set('accessToken', d.accessToken);",
                  "if (d.refreshToken) pm.collectionVariables.set('refreshToken', d.refreshToken);",
